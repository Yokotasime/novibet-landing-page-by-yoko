<!-- My Brazil one page website -->

<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600;700&display=swap" rel="stylesheet">
  <title>Novibet Brasil Links</title>

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: 'Open Sans', sans-serif;
      background: #202735;
      color: #ffffff;
      text-align: center;
      min-height: 100vh;
    }

    .page {
      max-width: 760px;
      margin: 0 auto;
      padding: 48px 20px 36px;
    }

    .logo {
      width: 200px;
      height: 200px;
      object-fit: contain;
      display: block;
      margin: 0 auto 24px;
      border-radius: 36px;
    }

    h1 {
      margin: 0 0 14px;
      font-size: 56px;
      line-height: 1.05;
      font-weight: 700;
      color: #ffffff;
    }

    .intro-text {
      font-size: 18px;
      line-height: 1.55;
      margin: 0 auto 28px;
      max-width: 640px;
      color: #ffffff;
    }

    .intro-text a {
      color: #1da1f2;
      text-decoration: none;
      font-weight: 600;
    }

    .intro-text a:hover {
      color: #0d8ae5;
    }

    .video-wrap {
      max-width: 700px;
      margin: 0 auto 34px;
      border-radius: 20px;
      overflow: hidden;
      box-shadow: 0 10px 28px rgba(0,0,0,0.28);
    }

    .video-ratio {
      position: relative;
      width: 100%;
      padding-top: 56.25%;
      background: #000;
    }

    .video-ratio iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }

    .links {
      display: flex;
      flex-direction: column;
      gap: 14px;
      margin: 0 auto 34px;
      max-width: 640px;
    }

    .link-pill {
      display: block;
      text-decoration: none;
      color: #ffffff;
      background: linear-gradient(180deg, #223252 0%, #1b2943 100%);
      border-radius: 999px;
      padding: 18px 24px;
      font-size: 20px;
      font-weight: 600;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .link-pill:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 24px rgba(0,0,0,0.35);
    }

    .pill-with-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
    }

    .pill-icon {
      width: 38px;
      height: 38px;
      object-fit: cover;
      border-radius: 8px;
      flex-shrink: 0;
    }

    .social-icons {
      display: flex;
      justify-content: center;
      gap: 28px;
      flex-wrap: wrap;
      margin: 0 0 34px;
    }

    .social-icons a {
      display: inline-block;
      padding: 8px;
    }

    .social-icons a:hover {
      transform: scale(1.12);
    }

    .social-icons img {
      width: 52px;
      height: 52px;
      filter: brightness(0) invert(1);
      transition: transform 0.2s ease;
    }

    .footer-note {
      max-width: 720px;
      margin: 0 auto;
      font-size: 13px;
      line-height: 1.55;
      color: #8f96a3;
      font-style: italic;
    }

    @media (max-width: 767px) {
      .page {
        padding: 20px 16px 32px;
        position: relative;
        overflow: hidden;
      }

      .page::before {
        content: "";
        position: absolute;
        top: 10px;
        left: 12px;
        right: 12px;
        height: 45%;
        border-radius: 28px;
        background: linear-gradient(
          180deg,
          rgba(61,92,148,.45) 0%,
          rgba(34,50,82,.30) 55%,
          rgba(27,41,67,.10) 100%
        );
        box-shadow: 0 18px 40px rgba(0,0,0,.28);
        z-index: 0;
      }

      .page > * {
        position: relative;
        z-index: 1;
      }

      .logo {
        width: 130px;
        height: 130px;
        border-radius: 24px;
      }

      h1 {
        font-size: 36px;
      }

      .intro-text {
        font-size: 15px;
        padding: 0 10px;
      }

      .link-pill {
        font-size: 16px;
        padding: 16px 18px;
        border-radius: 22px;
      }

      .pill-icon {
        width: 32px;
        height: 32px;
      }

      .social-icons {
        gap: 8px;
        flex-wrap: nowrap;
        justify-content: center;
        padding: 0 12px;  
      }
        
      .social-icons a {
        padding: 4px;  
      }

      .social-icons img {
        width: 34px;
        height: 34px;
      }

      .footer-note {
        font-size: 11px;
        padding: 0 10px;
      }
    }
  </style>
</head>

